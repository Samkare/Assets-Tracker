# Copy to .env and adjust. Never commit .env.
NODE_ENV=development
PORT=3000

# SQLite database file (relative to repo root or absolute)
DB_PATH=./data/app.db

# Session signing secret — generate a long random string for production
SESSION_SECRET=change-me-to-a-long-random-string

# Bootstrap admin created on first seed (forced password reset on first login)
BOOTSTRAP_ADMIN_EMAIL=finnbelgium@gmail.com
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe!2026

# Source data for first-run seed (relative to repo root)
SEED_ROWS_PATH=../uploads/parsed-rows.json
